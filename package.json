{
  "name": "cyclehub",
  "version": "1.0.0",
  "private": true,
  "description": "骑改App (CycleHub) - 骑行爱好者改装好物分享社区",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:client": "pnpm --filter client start",
    "dev:server": "pnpm --filter server dev",
    "build": "pnpm --filter client export",
    "build:server": "pnpm --filter server build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
